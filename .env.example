# Same database as member portal
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# JWT secrets — can share the same secrets as member portal
JWT_SECRET="your-access-token-secret-here"
JWT_REFRESH_SECRET="your-refresh-token-secret-here"

# Admin credentials — set these to secure values
ADMIN_EMAIL="admin@insureportal.com"
ADMIN_PASSWORD="change-me-in-production"
